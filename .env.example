# Configuração geral
DJANGO_SECRET_KEY=SUBSTITUA-POR-UMA-CHAVE-ALEATORIA-LONGA
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,SEU_IP_DO_SERVIDOR
SYSTEM_NAME=Gestão de Contratos — SDAP
SYSTEM_ORGANIZATION=Subdiretoria de Apoio Administrativo

# Banco padrão para teste/local
DB_ENGINE=sqlite
SQLITE_PATH=db.sqlite3

# Para produção no Railway/ PostgreSQL, use:
# DB_ENGINE=postgresql
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco
# POSTGRES_DB=gestao_contratos
# POSTGRES_USER=gestao_contratos
# POSTGRES_PASSWORD=ALTERE_ESTA_SENHA
# POSTGRES_HOST=db
# POSTGRES_PORT=5432

# Variáveis do Railway
# RAILWAY_PUBLIC_DOMAIN=seu-app.up.railway.app
# PORT=8000

# Ative apenas quando houver HTTPS configurado
DJANGO_SECURE_COOKIES=0
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_HSTS_SECONDS=0
